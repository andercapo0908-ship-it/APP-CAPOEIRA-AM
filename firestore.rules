rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields: uid, email, role, nickname, photoURL, graduation, age, capoeiraTime, bio, gender, createdAt
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email.matches("andercapo0908@.*")) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'member'] &&
             (!('nickname' in data) || (data.nickname is string && data.nickname.size() <= 50)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500));
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'type', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.date is timestamp &&
             data.type in ['training', 'workshop', 'roda', 'other'] &&
             data.authorUid is string &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 200));
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['url', 'type', 'authorUid']) &&
             data.url is string && isValidUrl(data.url) &&
             data.type in ['image', 'video'] &&
             data.authorUid is string &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['authorUid', 'text']) &&
             data.authorUid is string &&
             data.text is string && data.text.size() <= 2000 &&
             (!('imageUrl' in data) || (data.imageUrl is string && isValidUrl(data.imageUrl)));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /config/{configId} {
      allow read: if true; // Allow public read for app configuration (logo, colors)
      allow write: if isAdmin();
    }

    match /configHistory/{historyId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'member' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                      (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid && isValidGalleryItem(request.resource.data);
      allow update: if isAuthenticated() && (
        // Author can update everything
        (resource.data.authorUid == request.auth.uid && isValidGalleryItem(request.resource.data)) || 
        // Others can only update likes and reactions
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'reactions'])
      );
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid && request.resource.data.text is string && request.resource.data.text.size() < 500;
        allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid && isValidMessage(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    match /store/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /masters/{masterId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.authorUid == request.auth.uid || isAdmin()) && isValidEvent(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin()) && isValidEvent(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    match /feeConfigs/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /trainingLogs/{logId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
      allow delete: if isAdmin();
    }

    match /nicknames/{nickname} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /eventNotices/{noticeId} {
      allow get: if isAuthenticated() && isValidId(noticeId);
      allow list: if isAuthenticated();
      allow create: if isAdmin() && isValidId(noticeId) && 
                      incoming().keys().hasAll(['title', 'description', 'importance', 'date', 'createdAt']) &&
                      incoming().title is string && incoming().title.size() <= 200 &&
                      incoming().description is string && incoming().description.size() <= 5000 &&
                      incoming().importance in ['normal', 'high', 'urgent'] &&
                      incoming().date is timestamp &&
                      incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(noticeId) &&
                      incoming().keys().hasAll(['title', 'description', 'importance', 'date', 'createdAt']) &&
                      incoming().title is string && incoming().title.size() <= 200 &&
                      incoming().description is string && incoming().description.size() <= 5000 &&
                      incoming().importance in ['normal', 'high', 'urgent'] &&
                      incoming().date is timestamp &&
                      incoming().createdAt == request.time;
      allow delete: if isAdmin() && isValidId(noticeId);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
