rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields: uid, email, role, nickname, photoURL, graduation, age, capoeiraTime, bio, gender, createdAt
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "andercapo0908@gmail.com") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'member'] &&
             (!('nickname' in data) || (data.nickname is string && data.nickname.size() < 50)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500));
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'type', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.date is timestamp &&
             data.type in ['training', 'workshop', 'roda', 'other'] &&
             data.authorUid is string &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 200));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'member' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                      (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Author can update everything
        resource.data.authorUid == request.auth.uid || 
        // Others can only update likes and reactions
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'reactions'])
      );
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
        allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    match /store/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /masters/{masterId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.authorUid == request.auth.uid || isAdmin()) && isValidEvent(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin()) && isValidEvent(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    match /feeConfigs/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /trainingLogs/{logId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
